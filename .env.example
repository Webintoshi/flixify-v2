VITE_SUPABASE_URL=https://sdsvnkvmfhaubgcahvzv.supabase.co

# Anon Key (Public) - Legacy Key kullanılmalı
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InNkc3Zua3ZtZmhhdWJnY2Fodnp2Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE4MTM1NDgsImV4cCI6MjA4NzM4OTU0OH0.KslfPrwrIhDBlshOG5_KVvTaOEKYw4vuoJ0VBUx01HQ

# API Configuration (Backend)
VITE_API_URL=/api

# IPTV Proxy Server URL (Coolify/Docker içinde)
# Coolify'da proxy service domaini veya internal docker network URL
# Örnek: http://proxy:3001 (Docker internal) veya https://proxy.flixify.pro
VITE_PROXY_URL=http://localhost:3001

# Allowed Origins for Proxy CORS (virgülle ayrılmış)
ALLOWED_ORIGINS=https://flixify.pro,https://www.flixify.pro,http://localhost:5173

# ============================================
# BACKEND ENVIRONMENT VARIABLES (Server-side)
# ============================================
# Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_URL=https://sdsvnkvmfhaubgcahvzv.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Stream Configuration
STREAM_PROXY_TIMEOUT=30000
MAX_CONCURRENT_STREAMS_DEFAULT=2

# Cache Configuration (dakika)
PLAYLIST_CACHE_TTL_MINUTES=5

# Session Configuration (saniye) - 4 saat
STREAM_SESSION_DURATION=14400

# ============================================
# BUNNY CDN / STREAM CONFIGURATION
# ============================================
# Bunny Stream (Video Hosting) - https://bunny.net/stream/
BUNNY_STREAM_API_KEY=ee82553e-5bf0-48d2-9a5f-6cc77ed98b2a
BUNNY_STREAM_LIBRARY_ID=93402489-666d-4a13-8fbe-c057d4e9c997

# Bunny CDN (Pull Zone) - https://bunny.net/cdn/
BUNNY_CDN_URL=https://flixify.b-cdn.net
BUNNY_CDN_API_KEY=ee82553e-5bf0-48d2-9a5f-6cc77ed98b2a

# Bunny Stream Signed URL Security
BUNNY_TOKEN_SECURITY_KEY=ee82553e-5bf0-48d2-9a5f-6cc77ed98b2a

# Stream Provider Priority: bunny | iptv
# bunny: Önce Bunny Stream dener, yoksa IPTV'ye fallback
# iptv: Sadece kullanıcının M3U URL'sinden çeker
STREAM_PROVIDER_PRIORITY=bunny
