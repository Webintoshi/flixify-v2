# ============================================
# FLIXIFY V2 - ENVIRONMENT VARIABLES
# ============================================

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# API Configuration (Backend)
VITE_API_URL=https://your-domain.com/api
# Development için: http://localhost:3000/api

# Optional: Stream Proxy Configuration
STREAM_PROXY_TIMEOUT=30000
MAX_CONCURRENT_STREAMS_PER_USER=2

# Optional: Cache Configuration
PLAYLIST_CACHE_TTL_MINUTES=5

# Optional: Analytics (Sentry)
# VITE_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
